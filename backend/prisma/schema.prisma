  isActive Boolean @default(true)

  // Optional marketing/info fields (matching token details page)
  description String?   @db.Text
  website     String?
  whitepaper  String?
  twitter     String?
  discord     String?
  categories  String[] // ["DeFi", "Layer 1", etc.]
  genesisDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("demo_college_coins")
}

// ============================================
// GLOBAL ASSET MANAGEMENT (New Token System)
// ============================================

enum AssetType {
  CRYPTO
  COLLEGE_COIN
  LAND
  COMMODITY
  CELEBRITY
}

model Token {
  id      String  @id @default(uuid())
  symbol  String  @unique // BTC, ETH, TUIT, etc.
  name    String // Bitcoin, Ethereum, Tuition Coin
  iconUrl String?

  // Price Discovery Identity
  coingeckoId     String? // e.g. "bitcoin", "tuition-coin"
  contractAddress String? // e.g. "0x963cd..."
  chain           String? // e.g. "ethereum", "base", "solana" (Generic slug for API)

  // Manual Price Fallback (if no API data found or preferred)
  manualPrice Decimal @default(0) @db.Decimal(20, 8)

  // Live UGX price, 24h change, 24h volume — written by price-cache.service every ~60s from CoinGecko
  currentPrice    Decimal   @default(0) @db.Decimal(20, 8)
  change24h       Float     @default(0)
  volume24h       Decimal   @default(0) @db.Decimal(24, 2)
  pricesUpdatedAt DateTime?

  // Toggles (9 standard permissions)
  allowBuy       Boolean @default(false)
  allowSell      Boolean @default(false)
  allowTradeUsdt Boolean @default(false)
  allowTradeUgx  Boolean @default(true)
  allowTradeEth  Boolean @default(false)
  allowTradeTuit Boolean @default(false)
  allowDeposit   Boolean @default(false)
  allowWithdraw  Boolean @default(false)
  allowP2P       Boolean @default(false)

  // Transaction Limits (USD Value)
  minTransactionAmount Decimal @default(10) @db.Decimal(20, 8)
  maxTransactionAmount Decimal @default(5000) @db.Decimal(20, 8)

  // College Coin specific fields
  /// Real college token from CFC (for mining/trading). NOT related to DemoCollegeCoin.
  isCollegeCoin      Boolean @default(false)
  miningAllowed      Boolean @default(false)
  collegeCfcId       String? // CFC MongoDB college _id (for migration linkage)
  collegeName        String?
  collegeCountry     String?
  collegeLogo        String?
  miningBaseRate     Float   @default(0.25) // tokens per hour
  miningSessionHours Int     @default(24) // session duration in hours

  // Custom Asset Specific Fields
  assetType          AssetType @default(CRYPTO)
  landAddress        String?
  commodityType      String?
  celebrityName      String?

  // Token Type
  /// True for platform-native tokens (TUIT, college coins) that trade internally.
  /// False for standard crypto (BTC, ETH) that are here only for permission settings.
  isNative Boolean @default(false)

  // Status & Metadata
  isActive    Boolean @default(true)
  description String? @db.Text
  website     String?
  whitepaper  String?
  twitter     String?
  discord     String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // Relations
  miningSessions     MiningSession[]
  miningCollegeUsers UserMiningCollege[] @relation("MiningCollegeTokens")

  @@map("tokens")
}

model GlobalAssetSettings {
  id String @id @default("singleton")

  // Default permission toggles
  defaultAllowBuy       Boolean @default(false)
  defaultAllowSell      Boolean @default(false)
  defaultAllowP2P       Boolean @default(false)
  defaultAllowDeposit   Boolean @default(false)
  defaultAllowWithdraw  Boolean @default(false)
  defaultAllowTradeUgx  Boolean @default(false)
  defaultAllowTradeUsdt Boolean @default(false)
  defaultAllowTradeEth  Boolean @default(false)
  defaultAllowTradeTuit Boolean @default(false)

  // Default transaction limits
  defaultMinTransaction Decimal @default(10) @db.Decimal(20, 8)
  defaultMaxTransaction Decimal @default(5000) @db.Decimal(20, 8)

  // Default mining settings
  defaultMiningBaseRate     Float @default(0.25)
  defaultMiningSessionHours Int   @default(24)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("global_asset_settings")
}

// Live mode portfolio snapshots (for investor mode growth chart)
model PortfolioSnapshot {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Portfolio values at snapshot time
  totalValue    Decimal @db.Decimal(20, 8) // Current total value
  investedValue Decimal @db.Decimal(20, 8) // Total deposits - total withdrawals
  cashBalance   Decimal @db.Decimal(20, 8) // USD balance
  cryptoValue   Decimal @db.Decimal(20, 8) // Total crypto value at market prices

  // Snapshot timestamp - one per day
  snapshotDate DateTime @db.Date

  createdAt DateTime @default(now())

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate])
  @@map("portfolio_snapshots")
}

// ============================================
// TUIT TRANSFER (Vesting Contract Migration)
// ============================================

// Authorized wallets from CSV - stores investor allocation data
model TuitAuthorizedWallet {
  id            String  @id @default(uuid())
  name          String // Investor name from CSV
  email         String? // Email (can be null, can repeat)
  walletAddress String  @unique // Wallet address (unique identifier)

  // Status tracking
  isActive Boolean @default(true) // Admin can deactivate

  // Test pair fields (for admin demo - bypasses contract calls, OTP, and one-time limits)
  isTestPair         Boolean  @default(false)
  testTotalAllocated Decimal? @db.Decimal(30, 18)
  testUnlocked       Decimal? @db.Decimal(30, 18)
  testWithdrawn      Decimal? @db.Decimal(30, 18)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transfers TuitTransfer[]

  @@index([email])
  @@map("tuit_authorized_wallets")
}

// Flow 1: Transfer from vesting allocation to platform balance
model TuitTransfer {
  id String @id @default(uuid())

  // User who claimed the transfer
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Authorized wallet used for this transfer
  authorizedWalletId String
  authorizedWallet   TuitAuthorizedWallet @relation(fields: [authorizedWalletId], references: [id])

  // Email used for verification (may differ from user's email)
  verificationEmail String

  // Amounts from smart contract at time of transfer
  totalAllocated Decimal @db.Decimal(30, 18) // Total tokens allocated
  totalUnlocked  Decimal @db.Decimal(30, 18) // Total unlocked
  totalWithdrawn Decimal @db.Decimal(30, 18) // Already withdrawn to external wallet
  amountCredited Decimal @db.Decimal(30, 18) // Amount credited to platform (available at time)

  // Status
  status TuitTransferStatus @default(COMPLETED)

  createdAt DateTime @default(now())

  @@unique([authorizedWalletId]) // One transfer per authorized wallet
  @@unique([userId, authorizedWalletId]) // User can only claim each wallet once
  @@index([userId])
  @@map("tuit_transfers")
}

enum TuitTransferStatus {
  COMPLETED // Successfully credited to user
  FAILED // Failed to credit (for logging)
}

// Flow 2: Conversion request for already withdrawn tokens
model TuitConversionRequest {
  id String @id @default(uuid())

  // User requesting conversion
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Transaction details
  txHash String @unique // Transaction hash of transfer to deposit wallet

  // Amount (parsed from transaction by admin or auto-detected)
  amount Decimal? @db.Decimal(30, 18) // Amount of TUIT in the transaction

  // Status
  status TuitConversionStatus @default(PENDING)

  // Admin review
  reviewedBy  String? // Admin user ID who reviewed
  reviewNotes String? // Admin notes
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("tuit_conversion_requests")
}

enum TuitConversionStatus {
  PENDING // Awaiting admin review
  APPROVED // Approved and credited
  REJECTED // Rejected by admin
}

// ============================================
// COLLEGE COIN MINING & CFC INTEGRATION
// ============================================

model MiningSession {
  id           String              @id @default(uuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId      String
  token        Token               @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  startTime    DateTime
  endTime      DateTime
  earningRate  Float
  tokensEarned Float               @default(0)
  isActive     Boolean             @default(true)
  stoppedAt    DateTime?
  status       MiningSessionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, tokenId, isActive])
  @@index([endTime, isActive])
  @@index([userId, isActive, endTime])
  @@map("mining_sessions")
}

enum MiningSessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

model UserMiningCollege {
  id      String   @id @default(uuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId String
  token   Token    @relation("MiningCollegeTokens", fields: [tokenId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([userId, tokenId])
  @@index([userId])
  @@map("user_mining_colleges")
}

model UserMiningProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cfcUserId          String?
  cfcMigrationDate   DateTime?
  cfcMigrationStatus CfcMigrationStatus @default(NOT_STARTED)
  totalTokensMined   Float              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_mining_profiles")
}

enum CfcMigrationStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model CfcLink {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cfcUserId       String        @unique
  cfcEmail        String
  bridgeToken     String
  bridgeTokenHash String
  status          CfcLinkStatus @default(ACTIVE)
  linkedAt        DateTime      @default(now())
  revokedAt       DateTime?

  @@map("cfc_links")
}

enum CfcLinkStatus {
  ACTIVE
  REVOKED
}

model MigrationRecord {
  id           String                @id @default(uuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cfcWalletId  String                @unique
  collegeCfcId String
  tokenSymbol  String
  amount       Float
  status       MigrationRecordStatus @default(PENDING)
  migratedAt   DateTime              @default(now())
  errorMessage String?

  @@index([userId])
  @@map("migration_records")
}

enum MigrationRecordStatus {
  PENDING
  COMPLETED
  FAILED
}

// ============================================
// CRON HELPERS
// ============================================

model DailyAssetPrice {
  id    String   @id @default(uuid())
  asset String // BTC, ETH, etc.
  price Decimal  @db.Decimal(20, 8) // Price at midnight UTC
  date  DateTime @db.Date // The date this price represents

  createdAt DateTime @default(now())

  @@unique([asset, date])
  @@index([date])
  @@map("daily_asset_prices")
}
