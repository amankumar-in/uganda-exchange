// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  emailVerified        Boolean   @default(false)
  phone                String    @unique
  phoneCountry         String
  phoneVerified        Boolean   @default(false)
  passwordHash         String
  country              String    @default("UG")
  kycStatus            KycStatus @default(APPROVED)
  role                 UserRole  @default(USER)
  appMode              AppMode   @default(INVESTOR) // Current trading mode preference
  // Set when the learner-mode WelcomeModal is dismissed. Account-scoped (not
  // device-scoped via localStorage) so the modal doesn't reappear when the
  // user signs in from a different device or browser.
  learnerWelcomeSeenAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations - Live Mode
  kyc                     Kyc?
  fiatBalance             FiatBalance?
  cryptoBalances          CryptoBalance[]
  depositAddresses        DepositAddress[]
  trades                  Trade[]
  fiatTransactions        FiatTransaction[]
  cryptoTransactions      CryptoTransaction[]
  creditCards             CreditCard[]
  bankAccounts            BankAccount[]
  withdrawalAddresses     WithdrawalAddress[]
  watchlistItems          WatchlistItem[]
  notificationPreferences NotificationPreferences?
  portfolioSnapshots      PortfolioSnapshot[]

  // P2P OTC Relations
  p2pAds              P2PAd[]
  p2pTradesAsBuyer    P2PTrade[]         @relation("BuyerTrades")
  p2pTradesAsSeller   P2PTrade[]         @relation("SellerTrades")
  p2pDisputesOpened   P2PDispute[]       @relation("DisputeOpener")
  p2pDisputesResolved P2PDispute[]       @relation("DisputeResolver")
  p2pPaymentMethods   P2PPaymentMethod[]
  p2pUserStats        P2PUserStats?

  // Relations - Learner Mode (Virtual Trading)
  learnerFiatBalance        LearnerFiatBalance?
  learnerCryptoBalances     LearnerCryptoBalance[]
  learnerTrades             LearnerTrade[]
  learnerPortfolioSnapshots LearnerPortfolioSnapshot[]

  // TUIT Transfer (Vesting Migration)
  tuitTransfers          TuitTransfer[]
  tuitConversionRequests TuitConversionRequest[]

  // College Coin Mining & CFC Integration
  miningProfile    UserMiningProfile?
  miningSessions   MiningSession[]
  miningColleges   UserMiningCollege[]
  cfcLink          CfcLink?
  migrationRecords MigrationRecord[]

  @@map("users")
}

enum KycStatus {
  PENDING
  SUBMITTED
  IN_REVIEW // Admin pause — auto-decide hit a soft fail (e.g. PAN-Aadhaar link unknown), needs manual sign-off
  APPROVED
  REJECTED
  EXPIRED // Periodic re-KYC due (compliance refresh window elapsed)
}

enum UserRole {
  USER
  ADMIN
}

enum AppMode {
  LEARNER // Practice trading with virtual funds
  INVESTOR // Real trading with actual funds
}

// ============================================
// KYC / ONBOARDING
// ============================================

model Kyc {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Consent (Step 1)
  consentedAt DateTime?

  // PAN (Step 2) — Sandbox /kyc/pan/verify
  // @unique so the same PAN can't be used across multiple accounts
  pan               String?   @unique
  panName           String? // Name as per PAN (authoritative from NSDL)
  panDob            DateTime? // DOB user submitted (verified by Sandbox)
  panStatus         String? // valid / invalid / not_found etc.
  panNameMatch      Boolean? // Did user-submitted name match PAN records
  panDobMatch       Boolean? // Did user-submitted DOB match PAN records
  panAadhaarSeeding String? // linked / not_linked from PAN verify
  panVerifiedAt     DateTime?
  panRawData        Json? // Full Sandbox response for audit

  // Aadhaar (Steps 3-4) — Sandbox /kyc/aadhaar/okyc
  aadhaarLast4          String? // Only last 4 stored for display (compliance)
  // Salted SHA-256 of the full 12-digit Aadhaar; @unique so same Aadhaar
  // can't be used across accounts. Full number itself is never stored.
  // Written ONLY after successful OTP verification — not on OTP request — so
  // a user who mistypes their Aadhaar can't pollute the unique-namespace and
  // lock the real Aadhaar-holder out.
  aadhaarHash           String?   @unique
  aadhaarRefId          String? // reference_id from OTP-gen; cleared after OTP verify or TTL
  aadhaarRefIdExpiresAt DateTime? // Sandbox/UIDAI ref ids expire ~10-30 min — we treat anything past this as gone
  aadhaarOtpSentAt      DateTime?
  aadhaarVerifiedAt     DateTime?
  aadhaarName           String? // Name as per Aadhaar (UIDAI-authoritative)
  aadhaarDob            DateTime?
  aadhaarYob            String? // Year of birth (when DOB not available)
  aadhaarGender         String?
  aadhaarCareOf         String?
  aadhaarPhotoPath      String? // local path under uploads/kyc/
  aadhaarRawData        Json? // Full Sandbox response (photo base64 stripped)

  // Address (Step 5) — prefilled from Aadhaar, user can edit flat/apt
  street1    String?
  street2    String?
  city       String?
  region     String? // Ugandan district name
  postalCode String? // pincode
  country    String? // "UG"

  // Selfie (Step 6)
  selfiePath       String?
  selfieUploadedAt DateTime?

  // PAN <-> Aadhaar linkage (computed after Aadhaar verify)
  panAadhaarLinked   Boolean?
  panAadhaarLinkedAt DateTime?

  // Decision
  status          KycStatus @default(PENDING)
  rejectionReason String?
  autoDecidedAt   DateTime?

  // Last Sandbox transaction id (their support requires this to debug). Updated on
  // every Sandbox call so we can surface it in error messages and logs.
  lastSandboxTxnId String?

  // Onboarding Progress
  // 0: intro, 1: consented, 2: pan verified, 3: aadhaar# submitted (OTP sent),
  // 4: aadhaar verified, 5: address confirmed, 6: selfie uploaded, 7: done
  currentStep Int @default(0)

  // Admin manual override
  reviewNotes String?
  reviewedAt  DateTime?
  reviewedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // History snapshots — every submission creates a row so a regulator can see
  // what was submitted and when, even after the user retries.
  submissions KycSubmission[]

  @@index([status])
  @@map("kyc")
}

// Append-only snapshot of every KYC submission. Reset/retry preserves history;
// the live `Kyc` row reflects only the most recent attempt, while this table
// answers "what did this user submit on date X" for audit / regulator review.
model KycSubmission {
  id     String @id @default(uuid())
  kycId  String
  kyc    Kyc    @relation(fields: [kycId], references: [id], onDelete: Cascade)
  userId String

  // Snapshot fields (copied from Kyc at submission time — never mutated after)
  pan              String?
  panName          String?
  panStatus        String?
  panNameMatch     Boolean?
  panDobMatch      Boolean?
  aadhaarLast4     String?
  aadhaarName      String?
  aadhaarDob       DateTime?
  panAadhaarLinked Boolean?
  status           KycStatus
  rejectionReason  String?
  decisionType     String? // AUTO_APPROVE, AUTO_REJECT, MANUAL_REVIEW, etc.

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([kycId])
  @@map("kyc_submissions")
}

// ============================================
// KYC REGIONAL RESTRICTIONS
// ============================================

model AllowedCountry {
  id             String   @id @default(uuid())
  countryCode    String   @unique // ISO 3166-1 alpha-2 (US, CA, GB)
  countryName    String
  isActive       Boolean  @default(true)
  allowAllStates Boolean  @default(false) // If true, all states allowed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  allowedStates AllowedState[]

  @@map("allowed_countries")
}

model AllowedState {
  id        String         @id @default(uuid())
  countryId String
  country   AllowedCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  stateCode String // ISO 3166-2 subdivision (CA, NY, TX)
  stateName String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([countryId, stateCode])
  @@map("allowed_states")
}

model KycRejectionLog {
  id                  String   @id @default(uuid())
  kycId               String
  userId              String
  rejectionType       String // PAN_INVALID, PAN_NAME_MISMATCH, AADHAAR_FAIL, NAME_MISMATCH, RESTRICTED_STATE, RESTRICTED_COUNTRY
  userProvidedCountry String?
  userProvidedState   String?
  documentCountry     String?
  documentState       String?
  reason              String
  providerRefId       String? // Sandbox reference id or equivalent
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([kycId])
  @@map("kyc_rejection_logs")
}

// ============================================
// FIAT BALANCES & ACCOUNTS
// ============================================

model FiatBalance {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency         String  @default("UGX")
  balance          Decimal @default(0) @db.Decimal(20, 8)
  availableBalance Decimal @default(0) @db.Decimal(20, 8)
  lockedBalance    Decimal @default(0) @db.Decimal(20, 8)

  updatedAt DateTime @updatedAt

  @@map("fiat_balances")
}

model BankAccount {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountNumber       String // Last 4 digits for display
  routingNumber       String // Masked for display
  accountType         String // checking, savings
  accountName         String
  stripeBankAccountId String? @unique // Stripe payment method ID or bank account ID
  isVerified          Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("bank_accounts")
}

model CreditCard {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCardId String @unique
  last4        String
  brand        String
  expiryMonth  Int
  expiryYear   Int

  createdAt DateTime @default(now())

  @@map("credit_cards")
}

model FiatTransaction {
  id            String  @id @default(uuid())
  transactionId String? @unique // Human-readable ID like TXN-00012345
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      FiatTransactionType // deposit, withdrawal
  method    String // wire, card, bank
  amount    Decimal             @db.Decimal(20, 8)
  status    TransactionStatus   @default(PENDING)
  reference String?
  metadata  Json? // Additional data (Stripe payment intent, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fiat_transactions")
}

enum FiatTransactionType {
  DEPOSIT
  WITHDRAWAL
}

// ============================================
// CRYPTO BALANCES & WALLETS
// ============================================

model CryptoBalance {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  asset            String // BTC, ETH, etc.
  balance          Decimal @default(0) @db.Decimal(20, 8)
  availableBalance Decimal @default(0) @db.Decimal(20, 8)
  lockedBalance    Decimal @default(0) @db.Decimal(20, 8)

  updatedAt DateTime @updatedAt

  @@unique([userId, asset])
  @@map("crypto_balances")
}

model DepositAddress {
  id      String  @id @default(uuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset   String // BTC, ETH, etc.
  address String  @unique
  network String
  memo    String?

  createdAt DateTime @default(now())

  @@unique([userId, asset])
  @@map("deposit_addresses")
}

model WithdrawalAddress {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  asset         String
  address       String
  label         String
  network       String
  isWhitelisted Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("withdrawal_addresses")
}

model CryptoTransaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  asset         String
  type          CryptoTransactionType // deposit, withdrawal
  amount        Decimal               @db.Decimal(20, 8)
  address       String
  txHash        String?
  status        TransactionStatus     @default(PENDING)
  confirmations Int                   @default(0)
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("crypto_transactions")
}

enum CryptoTransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// TRADING
// ============================================

model Trade {
  id            String  @id @default(uuid())
  transactionId String? @unique // Human-readable ID like TXN-00012345
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String // BTC-USD (Coinbase format)
  asset     String // BTC
  quote     String // USD
  side      OrderType // BUY, SELL

  // Order amounts
  requestedAmount Decimal @db.Decimal(20, 8) // Amount user requested
  filledAmount    Decimal @default(0) @db.Decimal(20, 8) // Amount actually filled
  price           Decimal @db.Decimal(20, 8) // Execution price
  totalValue      Decimal @db.Decimal(20, 8) // Total value in quote currency

  // Fees
  platformFee Decimal @default(0) @db.Decimal(20, 8)
  exchangeFee Decimal @default(0) @db.Decimal(20, 8)

  // Status & external reference
  status          TradeStatus @default(PENDING)
  coinbaseOrderId String?     @unique

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@map("trades")
}

enum OrderType {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// P2P OTC MARKETPLACE
// ============================================

// User's saved payment methods for P2P
model P2PPaymentMethod {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     P2PPaymentMethodType // BANK_TRANSFER, MOBILE_MONEY, PAYPAL, etc.
  name     String // Display name: "My Bank Account", "PayPal"
  details  Json // Encrypted/masked details specific to payment type
  isActive Boolean              @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ads using this payment method
  ads P2PAdPaymentMethod[]

  @@map("p2p_payment_methods")
}

enum P2PPaymentMethodType {
  BANK_TRANSFER
  MOBILE_MONEY
  PAYPAL
  VENMO
  ZELLE
  CASH_APP
  WISE
  REVOLUT
  OTHER
}

// P2P Advertisement (maker posts an ad to buy/sell crypto)
model P2PAd {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // What is being traded
  side         P2PAdSide // SELL (maker sells crypto) or BUY (maker buys crypto)
  asset        String // Crypto asset: BTC, ETH, etc.
  fiatCurrency String // Fiat or payment asset: USD, EUR, etc.

  // Pricing (fixed price only)
  price Decimal @db.Decimal(20, 8) // Fixed price per unit

  // Quantity
  totalQty     Decimal @db.Decimal(20, 8) // Total quantity for the ad
  remainingQty Decimal @db.Decimal(20, 8) // Remaining quantity available
  minQty       Decimal @db.Decimal(20, 8) // Minimum per trade
  maxQty       Decimal @db.Decimal(20, 8) // Maximum per trade

  // Ad status
  status P2PAdStatus @default(ACTIVE)

  // Terms and conditions (optional)
  terms String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  paymentMethods P2PAdPaymentMethod[]
  trades         P2PTrade[]

  @@index([userId])
  @@index([status])
  @@index([asset, fiatCurrency])
  @@index([side, status])
  @@map("p2p_ads")
}

enum P2PAdSide {
  BUY // Maker wants to buy crypto (taker sells)
  SELL // Maker wants to sell crypto (taker buys)
}

enum P2PAdStatus {
  ACTIVE
  PAUSED
  CLOSED
}

// Junction table for Ad <-> PaymentMethod (many-to-many)
model P2PAdPaymentMethod {
  id              String           @id @default(uuid())
  adId            String
  ad              P2PAd            @relation(fields: [adId], references: [id], onDelete: Cascade)
  paymentMethodId String
  paymentMethod   P2PPaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([adId, paymentMethodId])
  @@map("p2p_ad_payment_methods")
}

// P2P Trade (created when taker accepts an ad)
model P2PTrade {
  id          String @id @default(uuid())
  tradeNumber String @unique // Human-readable: P2P-20241222-ABC123

  // Parties
  adId         String
  ad           P2PAd  @relation(fields: [adId], references: [id])
  buyerUserId  String
  buyer        User   @relation("BuyerTrades", fields: [buyerUserId], references: [id])
  sellerUserId String
  seller       User   @relation("SellerTrades", fields: [sellerUserId], references: [id])

  // Trade details
  asset        String // Crypto asset being traded
  fiatCurrency String // Fiat currency for payment
  qtyCrypto    Decimal @db.Decimal(20, 8) // Amount of crypto
  price        Decimal @db.Decimal(20, 8) // Price per unit at trade creation
  notional     Decimal @db.Decimal(20, 8) // = qtyCrypto * price (fiat value)

  // Payment
  paymentMethodType P2PPaymentMethodType // Selected payment method
  paymentDetails    Json? // Seller's payment details for this trade

  // Timing
  paymentWindowSeconds Int      @default(900) // 15 minutes default
  expiresAt            DateTime // When payment must be made by

  // Proof of payment
  proofRequired Boolean  @default(true)
  proofUrls     String[] // URLs to uploaded proof images

  // State machine
  status P2PTradeStatus @default(CREATED)

  // Idempotency keys (for preventing duplicate operations)
  createIdempotencyKey   String? @unique
  markPaidIdempotencyKey String? @unique
  releaseIdempotencyKey  String? @unique
  cancelIdempotencyKey   String? @unique

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime?
  releasedAt  DateTime?
  cancelledAt DateTime?

  // Relations
  escrow    P2PEscrow?
  dispute   P2PDispute?
  auditLogs P2PAuditLog[]

  @@index([buyerUserId])
  @@index([sellerUserId])
  @@index([status])
  @@index([adId])
  @@map("p2p_trades")
}

enum P2PTradeStatus {
  CREATED // Trade created, escrow locked, timer running
  CANCELLED // Buyer cancelled before paid, or auto-expired unpaid
  PAID // Buyer marked paid with mandatory proof
  DISPUTED // Either party opened dispute after PAID
  RELEASED // Seller released escrow, funds credited to buyer
  REFUNDED // Dispute resolved to seller, escrow unlocked back to seller
  EXPIRED // Unpaid timer elapsed (treated as CANCELLED with strike)
}

// Escrow Lock (holds crypto during trade)
model P2PEscrow {
  id      String   @id @default(uuid())
  tradeId String   @unique
  trade   P2PTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  asset     String // Crypto asset locked
  qtyLocked Decimal         @db.Decimal(20, 8) // Amount locked
  status    P2PEscrowStatus @default(LOCKED)

  lockedAt   DateTime  @default(now())
  releasedAt DateTime?
  unlockedAt DateTime?

  @@map("p2p_escrows")
}

enum P2PEscrowStatus {
  LOCKED // Crypto is held in escrow
  RELEASED // Escrow transferred to buyer
  UNLOCKED // Escrow returned to seller (cancel/refund)
}

// Dispute (opened when there's a conflict)
model P2PDispute {
  id      String   @id @default(uuid())
  tradeId String   @unique
  trade   P2PTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  openedById String
  openedBy   User     @relation("DisputeOpener", fields: [openedById], references: [id])
  reason     String   @db.Text
  evidence   String[] // URLs to evidence files

  status  P2PDisputeStatus   @default(OPEN)
  outcome P2PDisputeOutcome?

  // Resolution
  resolvedById String?
  resolvedBy   User?   @relation("DisputeResolver", fields: [resolvedById], references: [id])
  resolution   String? @db.Text // Admin notes on resolution

  openedAt   DateTime  @default(now())
  resolvedAt DateTime?

  @@map("p2p_disputes")
}

enum P2PDisputeStatus {
  OPEN
  RESOLVED
}

enum P2PDisputeOutcome {
  RELEASE_TO_BUYER // Escrow transfers to buyer
  REFUND_TO_SELLER // Escrow returns to seller
}

// Immutable Audit Log (for every state transition)
model P2PAuditLog {
  id      String   @id @default(uuid())
  tradeId String
  trade   P2PTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  action        String // CREATE, MARK_PAID, RELEASE, CANCEL, DISPUTE_OPEN, DISPUTE_RESOLVE, etc.
  triggeredBy   String // User ID or "SYSTEM" for auto actions
  previousState String? // Previous status
  newState      String // New status
  metadata      Json? // Additional context (amounts, reasons, etc.)

  createdAt DateTime @default(now())

  @@index([tradeId])
  @@index([createdAt])
  @@map("p2p_audit_logs")
}

// User P2P Stats (daily limits, strikes, etc.)
model P2PUserStats {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Daily trading volume (resets daily)
  dailyVolumeUsd  Decimal  @default(0) @db.Decimal(20, 8)
  dailyVolumeDate DateTime @db.Date // Date of the daily volume

  // Strike system
  strikeCount    Int       @default(0)
  lastStrikeAt   DateTime?
  suspendedUntil DateTime? // If suspended due to strikes

  // Stats
  totalTradesCompleted Int     @default(0)
  totalTradesCancelled Int     @default(0)
  totalVolumeBought    Decimal @default(0) @db.Decimal(20, 8) // In USD
  totalVolumeSold      Decimal @default(0) @db.Decimal(20, 8) // In USD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("p2p_user_stats")
}

// ============================================
// SYSTEM / ADMIN
// ============================================

model TradingPair {
  id       String  @id @default(uuid())
  asset    String // BTC
  base     String // USD
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([asset, base])
  @@map("trading_pairs")
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String?
  phone     String?
  code      String
  type      String // REGISTER, LOGIN, RESET, UPDATE_EMAIL, UPDATE_PHONE
  expiresAt DateTime
  verified  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("otp_codes")
}

// ============================================
// WATCHLIST
// ============================================

model WatchlistItem {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  asset   String // BTC, ETH, etc. (base currency)
  addedAt DateTime @default(now())

  @@unique([userId, asset])
  @@map("watchlist_items")
}

// ============================================
// USER SETTINGS
// ============================================

model NotificationPreferences {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email Notifications
  emailMarketing      Boolean @default(true) // Promotional emails, newsletters
  emailSecurityAlerts Boolean @default(true) // Login alerts, password changes
  emailTransactions   Boolean @default(true) // Deposit/withdrawal confirmations
  emailPriceAlerts    Boolean @default(false) // Price movement notifications
  emailNewsUpdates    Boolean @default(true) // Platform news and updates

  // Push Notifications
  pushEnabled        Boolean @default(true) // Master toggle for push
  pushSecurityAlerts Boolean @default(true) // Login alerts, suspicious activity
  pushTransactions   Boolean @default(true) // Trade confirmations
  pushPriceAlerts    Boolean @default(false) // Price alerts
  pushNewsUpdates    Boolean @default(false) // News and updates

  // SMS Notifications
  smsEnabled        Boolean @default(true) // Master toggle for SMS
  smsSecurityAlerts Boolean @default(true) // 2FA, login from new device
  smsTransactions   Boolean @default(false) // Large transaction alerts

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_preferences")
}

// ============================================
// LEARNER MODE (Virtual Trading)
// ============================================

model LearnerFiatBalance {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency         String  @default("UGX")
  balance          Decimal @default(500000) @db.Decimal(20, 8) // Starts with UGX 500,000
  availableBalance Decimal @default(500000) @db.Decimal(20, 8)
  lockedBalance    Decimal @default(0) @db.Decimal(20, 8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("learner_fiat_balances")
}

model LearnerCryptoBalance {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  asset            String // BTC, ETH, etc.
  balance          Decimal @default(0) @db.Decimal(20, 8)
  availableBalance Decimal @default(0) @db.Decimal(20, 8)
  lockedBalance    Decimal @default(0) @db.Decimal(20, 8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, asset])
  @@map("learner_crypto_balances")
}

model LearnerTrade {
  id            String  @id @default(uuid())
  transactionId String? @unique // Human-readable ID like LRN-00012345
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String // BTC-USD (same format as live)
  asset     String // BTC
  quote     String // USD
  side      OrderType // BUY, SELL

  // Order amounts
  requestedAmount Decimal @db.Decimal(20, 8)
  filledAmount    Decimal @default(0) @db.Decimal(20, 8)
  price           Decimal @db.Decimal(20, 8)
  totalValue      Decimal @db.Decimal(20, 8)

  // Fees (simulated)
  platformFee Decimal @default(0) @db.Decimal(20, 8)
  exchangeFee Decimal @default(0) @db.Decimal(20, 8)

  status      TradeStatus @default(PENDING)
  isSimulated Boolean     @default(true) // Always true for learner trades

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@map("learner_trades")
}

model LearnerPortfolioSnapshot {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Portfolio values at snapshot time
  totalValue    Decimal @db.Decimal(20, 8) // Current total value (fiat + crypto at market prices)
  investedValue Decimal @db.Decimal(20, 8) // Total deposits - withdrawals (always $10,000 for learner since no real deposits)
  cashBalance   Decimal @db.Decimal(20, 8) // USD balance at snapshot
  cryptoValue   Decimal @db.Decimal(20, 8) // Total crypto value at market prices

  // Snapshot timestamp - one per day
  snapshotDate DateTime @db.Date

  createdAt DateTime @default(now())

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate])
  @@map("learner_portfolio_snapshots")
}

// ============================================
// DEMO COLLEGE COINS (Learner Mode)
// ============================================

model DemoCollegeCoin {
  id      String  @id @default(uuid())
  ticker  String  @unique // MIT, HARV, STAN, etc.
  name    String // MIT Coin, Harvard Coin, etc.
  iconUrl String? // Path to icon in public/images/college-coins

  // Price pegging
  peggedToAsset    String // BTC, ETH, SOL, etc. (reference token)
  peggedPercentage Decimal @db.Decimal(10, 4) // 10.0000 = 10% of reference token price

